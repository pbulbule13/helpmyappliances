# HelpMyAppliances — Web dev environment
# Copy to .env.local:   cp web/env.dev web/.env.local
# DEV_MODE=true means no Firebase needed — just enter your email to log in.

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEV_MODE=true

# Firebase — only fill these when NEXT_PUBLIC_DEV_MODE=false (production)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=helpmyappliances.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=helpmyappliances
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=helpmyappliances.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
