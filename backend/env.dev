# HelpMyAppliances — Backend dev environment
# Copy this to .env:   cp backend/env.dev backend/.env
# Then run: bash setup.sh

APP_ENV=development
DEV_AUTH=true

DATABASE_URL=postgresql+asyncpg://app:password@postgres:5432/helpmyappliances
REDIS_URL=redis://redis:6379/0

EURI_API_KEY=your-euri-api-key-here

CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Firebase — only needed when DEV_AUTH=false (production)
FIREBASE_PROJECT_ID=helpmyappliances

GCS_BUCKET_NAME=helpmyappliances-uploads
GOOGLE_CLOUD_PROJECT=helpmyappliances
